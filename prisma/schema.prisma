generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  password          String
  name              String
  role              String             @default("USER")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  experiences       Experience[]
  jobAnalyses       JobAnalysis[]
  selfIntroductions SelfIntroduction[]
  documents         UserDocument[]
  companyReports    CompanyReport[]

  @@map("users")
}

model Experience {
  id        Int       @id @default(autoincrement())
  userId    String    @map("user_id")
  title     String
  situation String?
  task      String?
  action    String?
  result    String?
  insight   String?
  startedAt DateTime? @map("started_at")
  endedAt   DateTime? @map("ended_at")
  tags      Json?     @default("[]")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("experiences")
}

model JobAnalysis {
  id                Int                @id @default(autoincrement())
  userId            String             @map("user_id")
  companyName       String             @map("company_name")
  jdUrl             String?            @map("jd_url")
  jdRawText         String?            @map("jd_raw_text")
  analysisResult    Json?              @map("analysis_result") // Legacy JSON storage
  createdAt         DateTime           @default(now()) @map("created_at")
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobRoles          JobRole[]
  selfIntroductions SelfIntroduction[]

  @@map("job_analyses")
}

model JobRole {
  id                Int                @id @default(autoincrement())
  analysisId        Int                @map("analysis_id")
  roleTitle         String             @map("role_title") // 모집직무
  department        String?            @map("department") // 모집부문
  location          String?            @map("location")   // 근무지
  requirements      String?            @map("requirements")
  tasks             String?            @map("tasks")
  preferred         String?            @map("preferred")
  createdAt         DateTime           @default(now()) @map("created_at")
  jobAnalysis       JobAnalysis        @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  selfIntroductions SelfIntroduction[]

  @@map("job_roles")
}

model SelfIntroduction {
  id          Int             @id @default(autoincrement())
  userId      String          @map("user_id")
  analysisId  Int?            @map("analysis_id")
  roleId      Int?            @map("role_id")
  title       String          // Display title
  name        String?         // Draft name (e.g., "초안 1")
  isFinal     Boolean         @default(false) @map("is_final")
  status      String          @default("작성전") @map("status")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  items       SelfIntroItem[]
  jobAnalysis JobAnalysis?    @relation(fields: [analysisId], references: [id])
  jobRole     JobRole?        @relation(fields: [roleId], references: [id])
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("self_introductions")
}

model SelfIntroItem {
  id                 Int              @id @default(autoincrement())
  selfIntroductionId Int              @map("self_intro_id")
  question           String
  answer             String?
  aiGuide            String?          @map("ai_guide")
  charLimit          Int              @default(700) @map("char_limit")
  orderIndex         Int              @map("order_index")
  selfIntroduction   SelfIntroduction @relation(fields: [selfIntroductionId], references: [id], onDelete: Cascade)

  @@map("self_intro_items")
}

model UserDocument {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   // 'RESUME', 'COVER_LETTER', 'PORTFOLIO'
  fileName  String   @map("file_name")
  fileUrl   String   @map("file_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_documents")
}

model CompanyReport {
  id          Int      @id @default(autoincrement())
  userId      String   @map("user_id")
  companyName String   @map("company_name")
  reportData  Json     @map("report_data") // Stores { analysis: { 인재상, 조직문화 }, news: [] }
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyName])
  @@map("company_reports")
}
